#!/usr/bin/env bash
# hr — launch a Herdr room Lead for a given agent CLI, or the room Supervisor.
#
#   hr claude      -> orchestrator.sh
#   hr codex       -> codex-orchestrator.sh
#   hr opencode    -> opencode-orchestrator.sh
#   hr supervisor  -> opencode-supervisor.sh (cheapest model)
#   hr supervisor-codex -> codex-supervisor.sh (fallback)
#
# Extra arguments are forwarded to the underlying wrapper, e.g.
#   hr claude --model opus
#
# Implementer and peer profiles are intentionally not exposed here: they are
# spawned by the Lead through the herdr CLI, not by hand. The Supervisor is
# exposed because it audits the Lead, so the Lead must not own its lifecycle.
set -euo pipefail

PROFILE_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
Usage: hr <agent> [args...]

Leads:
  claude       Claude Code room Lead
  codex        Codex room Lead
  opencode     opencode room Lead

Audit:
  supervisor         Read-only room supervisor (opencode, free tier)
  supervisor-codex   Same role on Codex, if opencode is unavailable

Any extra arguments are passed through to the agent CLI.
EOF
}

agent="${1:-}"
[[ $# -gt 0 ]] && shift

case "$agent" in
  claude)     script="orchestrator.sh" ;;
  codex)      script="codex-orchestrator.sh" ;;
  opencode)   script="opencode-orchestrator.sh" ;;
  supervisor)       script="opencode-supervisor.sh" ;;
  supervisor-codex) script="codex-supervisor.sh" ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  "")
    usage >&2
    exit 1
    ;;
  *)
    printf 'hr: unknown agent %s\n\n' "$agent" >&2
    usage >&2
    exit 1
    ;;
esac

exec "$PROFILE_DIR/$script" "$@"
