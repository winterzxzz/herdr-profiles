{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "bridgememory": { "enabled": false }
  },
  "agent": {
    "reviewer": {
      "mode": "primary",
      "hidden": true,
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "medium",
      "description": "Read-only code review, no edits or delegation",
      "permission": {
        "*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "bash": {
          "*": "deny",
          "git status": "allow",
          "git status *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git show *": "allow",
          "git worktree list": "allow",
          "cat *": "allow",
          "ls": "allow",
          "ls *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "echo *": "allow"
        },
        "edit": "deny",
        "task": "deny",
        "todowrite": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "skill": "deny"
      }
    }
  }
}
