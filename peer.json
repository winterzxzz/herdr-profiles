{
  "model": "sonnet",
  "env": {
    "MAX_THINKING_TOKENS": "4096"
  },
  "permissions": {
    "deny": [
      "Edit",
      "Write",
      "NotebookEdit",
      "Bash(herdr:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git add:*)"
    ],
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)"
    ]
  }
}
